{
  "info": {
    "name": "FixHub Functional E2E (FUNC_)",
    "description": "Batería funcional E2E. Prefijo datos: FUNC_<timestamp>. Ver docs/QA/01_TEST_MATRIX.md y 02_HOW_TO_RUN.md",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5100" },
    { "key": "funcPrefix", "value": "FUNC_" },
    { "key": "funcTimestamp", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "customerEmail", "value": "" },
    { "key": "technicianToken", "value": "" },
    { "key": "technicianEmail", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "jobId", "value": "" },
    { "key": "proposalId", "value": "" },
    { "key": "customer2Token", "value": "" },
    { "key": "customer2Email", "value": "" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "var ts = pm.variables.replaceIn('{{$timestamp}}');",
          "if (!pm.collectionVariables.get('funcTimestamp')) pm.collectionVariables.set('funcTimestamp', ts);"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "01_AUTH",
