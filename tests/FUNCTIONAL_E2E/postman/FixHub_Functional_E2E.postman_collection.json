    {
      "name": "02_CUSTOMER",
      "item": [
        {
          "name": "Create Job (TC-003)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var j = pm.response.json();",
                "  if (j.id) pm.collectionVariables.set('jobId', j.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": 1,\n  \"title\": \"{{funcPrefix}}{{funcTimestamp}} Reparación\",\n  \"description\": \"Descripción FUNC_ E2E\",\n  \"addressText\": \"Calle Test 123\",\n  \"lat\": null,\n  \"lng\": null,\n  \"budgetMin\": 100,\n  \"budgetMax\": 200\n}"
            },
            "url": "{{baseUrl}}/api/v1/jobs",
            "description": "TC-003. Esperado: 201, status Open o Assigned."
          }
        },
        {
          "name": "Create Job - invalid category (TC-005)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": 99999,\n  \"title\": \"Invalid\",\n  \"description\": \"x\",\n  \"addressText\": \"x\",\n  \"lat\": null,\n  \"lng\": null,\n  \"budgetMin\": null,\n  \"budgetMax\": null\n}"
            },
            "url": "{{baseUrl}}/api/v1/jobs",
            "description": "TC-005. Esperado: 400 CATEGORY_NOT_FOUND."
          }
        },
        {
          "name": "List My Jobs (TC-006)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/mine?page=1&pageSize=20",
            "description": "TC-006. Esperado: 200, PagedResult con items."
          }
        },
        {
          "name": "Get Job by ID (TC-007)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}",
            "description": "TC-007. Esperado: 200, JobDto."
          }
        },
        {
          "name": "Get Job Proposals - Customer (TC-009)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/proposals",
            "description": "TC-009. Bug H04: puede devolver lista vacía. Esperado: 200 con propuestas si las hay."
          }
        },
        {
          "name": "Cancel Job (TC-010)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/cancel",
            "description": "TC-010. Solo si job en Open. Esperado: 200, status Cancelled."
          }
        },
        {
          "name": "Complete Job (TC-012)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/complete",
            "description": "TC-012. Job debe estar InProgress o Assigned. Esperado: 200, Completed."
          }
        },
        {
          "name": "Create Review (TC-014)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jobId\": \"{{jobId}}\",\n  \"stars\": 5,\n  \"comment\": \"{{funcPrefix}} Excelente servicio\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/reviews",
            "description": "TC-014. Job debe estar Completed. Esperado: 201."
          }
        },
        {
          "name": "Report Issue (TC-016)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"late\",\n  \"detail\": \"{{funcPrefix}} Detalle incidencia\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/issues",
            "description": "TC-016. Reason: no_contact|late|bad_service|other. Esperado: 201."
          }
        },
        {
          "name": "List Notifications (TC-017)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/notifications?page=1&pageSize=20",
            "description": "TC-017. Esperado: 200."
          }
        }
      ]
