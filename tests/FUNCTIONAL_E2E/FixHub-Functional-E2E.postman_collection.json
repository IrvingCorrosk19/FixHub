{
  "info": {
    "name": "FixHub Functional E2E",
    "description": "Batería funcional E2E por API. Prefijo TEST_<timestamp>. Ver docs/AUDIT/06_FUNCTIONAL_RESULTS.md",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5100" },
    { "key": "testPrefix", "value": "TEST_" },
    { "key": "customerEmail", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "technicianEmail", "value": "" },
    { "key": "technicianToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "jobId", "value": "" },
    { "key": "proposalId", "value": "" },
    { "key": "customer2Email", "value": "" },
    { "key": "customer2Token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Prep",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/v1/health",
            "description": "FASE 1. Esperado: 200, status healthy."
          }
        }
      ]
    },
    {
      "name": "2. Customer",
      "item": [
        {
          "name": "Register Customer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var j = pm.response.json();",
                "  if (j.token) pm.collectionVariables.set('customerToken', j.token);",
                "  if (j.email) pm.collectionVariables.set('customerEmail', j.email);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{testPrefix}} Customer\",\n  \"email\": \"{{testPrefix}}_{{$timestamp}}_cust@test.local\",\n  \"password\": \"Password1!\",\n  \"role\": 1,\n  \"phone\": null\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "FASE 2.1. API exige role; role 1 = Customer. Sin role → 400."
          }
        },
        {
          "name": "Login Customer",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var j = pm.response.json();",
                "  if (j.token) pm.collectionVariables.set('customerToken', j.token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"Password1!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "FASE 2.2."
          }
        },
        {
          "name": "Create Job (TEST_JOB_timestamp)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var j = pm.response.json();",
                "  if (j.id) pm.collectionVariables.set('jobId', j.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": 1,\n  \"title\": \"{{testPrefix}}_JOB_{{$timestamp}}\",\n  \"description\": \"E2E functional job\",\n  \"addressText\": \"123 Test St\",\n  \"lat\": null,\n  \"lng\": null,\n  \"budgetMin\": 100,\n  \"budgetMax\": 200\n}"
            },
            "url": "{{baseUrl}}/api/v1/jobs",
            "description": "FASE 2.3."
          }
        },
        {
          "name": "List My Jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/mine?page=1&pageSize=20",
            "description": "FASE 2.4. Validar: job creado en lista, campos obligatorios, status Open."
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}",
            "description": "FASE 2.5."
          }
        },
        {
          "name": "Register Customer 2",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var j = pm.response.json();",
                "  if (j.email) pm.collectionVariables.set('customer2Email', j.email);",
                "  if (j.token) pm.collectionVariables.set('customer2Token', j.token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{testPrefix}} Customer2\",\n  \"email\": \"{{testPrefix}}_{{$timestamp}}_c2@test.local\",\n  \"password\": \"Password1!\",\n  \"role\": 1,\n  \"phone\": null\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "Para validar 403: Customer B no ve job de A."
          }
        },
        {
          "name": "Login Customer 2",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var j = pm.response.json();",
                "  if (j.token) pm.collectionVariables.set('customer2Token', j.token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customer2Email}}\",\n  \"password\": \"Password1!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": ""
          }
        },
        {
          "name": "[Neg] Get Job by ID (other customer → 403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customer2Token}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}",
            "description": "FASE 2.7. Esperado: 403."
          }
        }
      ]
    },
    {
      "name": "3. Technician",
      "item": [
        {
          "name": "Register Technician",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var j = pm.response.json();",
                "  if (j.token) pm.collectionVariables.set('technicianToken', j.token);",
                "  if (j.email) pm.collectionVariables.set('technicianEmail', j.email);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{testPrefix}} Technician\",\n  \"email\": \"{{testPrefix}}_{{$timestamp}}_tech@test.local\",\n  \"password\": \"Password1!\",\n  \"role\": 2,\n  \"phone\": null\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register",
            "description": "FASE 3.1."
          }
        },
        {
          "name": "Login Technician",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var j = pm.response.json();",
                "  if (j.token) pm.collectionVariables.set('technicianToken', j.token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{technicianEmail}}\",\n  \"password\": \"Password1!\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "FASE 3.2."
          }
        },
        {
          "name": "List Jobs (Technician)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{technicianToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs?page=1&pageSize=20",
            "description": "FASE 3.3."
          }
        },
        {
          "name": "Create Proposal",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "  var j = pm.response.json();",
                "  if (j.id) pm.collectionVariables.set('proposalId', j.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{technicianToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 150,\n  \"message\": \"{{testPrefix}} proposal\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/proposals",
            "description": "FASE 3.4."
          }
        },
        {
          "name": "[Neg] Proposal duplicada",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{technicianToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 160,\n  \"message\": \"dup\"\n}" },
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/proposals",
            "description": "FASE 3.5. Esperado: 400/409."
          }
        },
        {
          "name": "[Neg] Proposal job inexistente",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{technicianToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"price\": 100,\n  \"message\": \"fake\"\n}" },
            "url": "{{baseUrl}}/api/v1/jobs/00000000-0000-0000-0000-000000000000/proposals",
            "description": "FASE 3.5. Esperado: 404/400."
          }
        }
      ]
    },
    {
      "name": "4. Interaction",
      "item": [
        {
          "name": "Login Admin (para Accept Proposal)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "  var j = pm.response.json();",
                "  if (j.token) pm.collectionVariables.set('adminToken', j.token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login",
            "description": "Ejecutar primero en Interaction. Setear adminEmail y adminPassword en environment."
          }
        },
        {
          "name": "Customer - List Proposals (own job)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/proposals",
            "description": "FASE 4.1. Nota: API actual puede devolver vacía (bug H04)."
          }
        },
        {
          "name": "Admin - Accept Proposal (asignar technician)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/v1/proposals/{{proposalId}}/accept",
            "description": "FASE 4.1. Solo Admin puede asignar en FixHub."
          }
        },
        {
          "name": "Technician - Start Job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{technicianToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/start",
            "description": "FASE 4.2."
          }
        },
        {
          "name": "Customer - Complete Job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/complete",
            "description": "FASE 4.3."
          }
        }
      ]
    },
    {
      "name": "5. Admin",
      "item": [
        {
          "name": "Admin - List Jobs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs?page=1&pageSize=20",
            "description": "FASE 5.2."
          }
        },
        {
          "name": "Admin - List Proposals (job)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/api/v1/jobs/{{jobId}}/proposals",
            "description": "FASE 5.3."
          }
        },
        {
          "name": "[Neg] Customer → Admin Dashboard (403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/dashboard",
            "description": "FASE 5.4. Esperado: 403."
          }
        },
        {
          "name": "[Neg] Technician → Admin Dashboard (403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{technicianToken}}" }],
            "url": "{{baseUrl}}/api/v1/admin/dashboard",
            "description": "FASE 5.4. Esperado: 403."
          }
        }
      ]
    }
  ]
}
